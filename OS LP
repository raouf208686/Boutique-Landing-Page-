        * { margin: 0; padding: 0; box-sizing: border-box; scroll-behavior: smooth; }

        body { 
            font-family: 'Inter', sans-serif; 
            background-color: var(--dark-bg); 
            color: var(--text-main); 
            overflow-x: hidden; 
            transition: 0.5s;
            letter-spacing: -0.02em; /* Style moderne tassé */
        }

        /* STYLE ARABE PREMIUM */
        body.rtl { direction: rtl; font-family: 'Noto Naskh Arabic', serif; }
        body.rtl .hero-title { font-family: 'Noto Naskh Arabic', serif; font-weight: 700; }

