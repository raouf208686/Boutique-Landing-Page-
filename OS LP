            --dark-bg: #000000; /* Noir absolu */
            --card-bg: #0a0a0a; /* Noir très légèrement grisé pour les cartes */
            --text-main: #ffffff; /* Blanc pur pour le texte */
            --text-muted: #888888; /* Gris pour les sous-titres */
