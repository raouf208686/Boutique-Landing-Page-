        .lang-switch { 
            position: fixed; top: 30px; right: 30px; z-index: 10000; 
            background: transparent; color: var(--gold); 
            border: 1px solid var(--border); 
            padding: 10px 20px; border-radius: 0px; /* Carré pro */
