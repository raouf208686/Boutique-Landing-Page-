        .hero-title { 
            font-family: 'Cinzel', serif; /* Police type gravure romaine */
            font-size: clamp(50px, 12vw, 130px); 
            font-weight: 700; color: var(--text-main); 
            line-height: 0.85; text-transform: uppercase; letter-spacing: -0.05em;
            margin-bottom: 20px;
        }
        .hero-sub {
            font-size: 10px; letter-spacing: 8px; text-transform: uppercase; 
            color: var(--gold); font-weight: 900;
        }

        /* SECTIONS - ESPACEMENT RESPIRANT */
        .section { 
            padding: 160px 20px; max-width: 1300px; margin: 0 auto; 
            border-bottom: 1px solid var(--border); 
        }
        .section-title { 
            font-family: 'Cinzel', serif; font-size: clamp(30px, 6vw, 60px); 
            font-weight: 700; color: var(--text-main); 
            text-transform: uppercase; letter-spacing: -0.03em;
            margin-bottom: 80px; text-align: center;
        }
        .section-title span { color: var(--gold); } /* Pour mettre en valeur un mot */

        /* BENTO GRID LUXE - BORDURES FINES, PAS D'OMBRE */
        .grid-detail { 
            display: grid; 
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); 
            gap: 1px; /* Espacement par la bordure */
            background-color: var(--border); /* Couleur de la bordure entre les cartes */
            border: 1px solid var(--border);
        }
        .card-lux { 
            background-color: var(--card-bg); 
            padding: 60px; 
            transition: 0.5s; 
            position: relative;
        }
        .card-lux:hover { background-color: #0f0f0f; } /* Très léger changement au survol */

        .card-lux b { 
            color: var(--gold); font-size: 10px; font-weight: 900; 
            text-transform: uppercase; letter-spacing: 3px; display: block; margin-bottom: 15px; 
        }
